model Friendship {
  id           BigInt   @id @default(autoincrement())
  status       String   @db.VarChar(10)
  created_at   DateTime @db.Timestamptz(6)
  from_user_id BigInt
  to_user_id   BigInt
  fromUser     User     @relation("friendship_from", fields: [from_user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  toUser       User     @relation("friendship_to", fields: [to_user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([from_user_id, to_user_id])
  @@index([from_user_id])
  @@index([to_user_id])
  @@map("user_app_friendship")
}

