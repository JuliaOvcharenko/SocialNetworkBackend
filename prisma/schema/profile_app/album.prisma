model Album {
  id        BigInt       @id @default(autoincrement())
  name      String       @db.VarChar(100)
  theme     String?      @db.VarChar(50)
  year      Int?
  isShown   Boolean      @map("is_shown")
  isDefault Boolean      @map("is_default")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  profileId BigInt       @map("profile_id")
  profile   Profile      @relation(fields: [profileId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "profile_app_album_profile_id_7414a460_fk_profile_app_profile_id")
  images    AlbumImage[]

  @@index([profileId], map: "profile_app_album_profile_id_7414a460")
  @@map("profile_app_album")
}
