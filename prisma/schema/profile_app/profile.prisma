model Profile {
  id                 BigInt    @id @default(autoincrement())
  birthDate          DateTime? @map("birth_date") @db.Date
  signature          String?   @db.VarChar(100)
  avatar             String?   @db.VarChar(100)
  pseudonym          String?   @db.VarChar(50)
  is_text_signature  Boolean
  is_image_signature Boolean
  userId             BigInt?   @unique @map("user_id")
  albums             Album[]
  user               User?     @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "profile_app_profile_user_id_296a7b55_fk_user_app_user_id")

  @@map("profile_app_profile")
}
