model ChatUser {
  id     BigInt @id @default(autoincrement())
  chatId BigInt @map("chat_id")
  userId BigInt @map("user_id")
  chat   Chat   @relation(fields: [chatId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "chat_app_chat_users_chat_id_5bba5169_fk_chat_app_chat_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "chat_app_chat_users_user_id_7aff58dc_fk_user_app_user_id")

  @@unique([chatId, userId], map: "chat_app_chat_users_chat_id_user_id_b05bfe90_uniq")
  @@index([chatId], map: "chat_app_chat_users_chat_id_5bba5169")
  @@index([userId], map: "chat_app_chat_users_user_id_7aff58dc")
  @@map("chat_app_chat_users")
}
