model PostLink {
  id     BigInt @id @default(autoincrement())
  url    String @db.VarChar(500)
  postId BigInt @map("post_id")
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "post_app_postlink_post_id_38de8dee_fk_post_app_post_id")
  @@index([postId], map: "post_app_postlink_post_id_38de8dee")
  @@map("post_app_postlink")
}
