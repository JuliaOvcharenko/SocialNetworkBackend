model Album {
  id         Int           @id @default(autoincrement())
  name       String
  topic      String?
  year       String?
  isShown    Boolean       @default(false)
  created_at DateTime      @default(now())
  tags       AlbumTags[]
  images     AlbumImages[]
  user       User          @relation(fields: [userId], references: [id])
  userId     Int
}
