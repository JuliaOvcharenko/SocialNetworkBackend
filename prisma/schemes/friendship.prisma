model Friendship {
  id             Int      @id @default(autoincrement())
  status         String   @default("pending")
  
  from_profile   Int
  to_profile     Int
  
  created_at     DateTime @default(now())

  fromProfileRel User     @relation("SentRequests", fields: [from_profile], references: [id], onDelete: Cascade)
  toProfileRel   User     @relation("ReceivedRequests", fields: [to_profile], references: [id], onDelete: Cascade)
}