model Image {
  id             Int           @id @default(autoincrement())
  pathname       String?
  uploaded_at    DateTime      @default(now())
  shakalImageURL String?
  normalImageURL String?
  postId         Int?
  albumId        Int?
  avatars        Avatar[]
  albumImages    AlbumImages[]
  post           Post?         @relation(fields: [postId], references: [id])
}
