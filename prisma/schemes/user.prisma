model User {
    id               Int          @id @default(autoincrement())
    name             String?
    surname          String?
    nickname         String?      @unique
    authorAlias      String?
    email            String       @unique
    birthDate        DateTime?
    password         String
    signature        String?
    isVerified       Boolean?     @default(false)
    verificationCode String?
    createdAt        DateTime     @default(now())
    updatedAt        DateTime     @updatedAt

    avatars          Avatar[] 
}

